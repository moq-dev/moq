#!/usr/bin/env just --justfile
#
# Language-specific recipes for the JavaScript / TypeScript packages under
# js/. Invoked from the repo root as `just js <recipe>` via the `mod js`
# import in the root justfile.

set working-directory := '.'

# Run all checks by default.
default:
	just check

install:
	bun install

# Lint, type-check, and biome-format all packages.
check:
	bun install --frozen-lockfile
	if tty -s; then \
		bun run --filter='*' --elide-lines=0 check; \
	else \
		bun run --filter='*' check; \
	fi
	bun biome check

# Auto-fix lint and formatting issues.
fix:
	bun install
	bun biome check --write

# Run all unit tests.
test:
	bun install --frozen-lockfile
	if tty -s; then \
		bun run --filter='*' --elide-lines=0 test; \
	else \
		bun run --filter='*' test; \
	fi

# Build all packages.
build:
	bun run --filter='*' build

# Full JS CI: lint + tests + build. Self-gates against BASE: exits 0 fast
# if no JS files changed (so root `just ci` can call this unconditionally).
# Pass BASE="" to force-run regardless of diff.
ci BASE="origin/main":
	#!/usr/bin/env bash
	set -euo pipefail
	if [[ -n "{{ BASE }}" ]] && [[ -z "$(just changed {{ BASE }})" ]]; then
		echo "js: no changes vs {{ BASE }}; skipping."
		exit 0
	fi
	just check
	just test
	just build

# Print "js" if any JS file changed vs BASE; else print nothing.
# Source of truth for what counts as a "JS change".
changed BASE="origin/main":
	#!/usr/bin/env bash
	set -euo pipefail
	if ! merge_base=$(git merge-base "{{ BASE }}" HEAD 2>/dev/null); then
		echo js
		exit 0
	fi
	if git diff --name-only "$merge_base" | grep -qE '^(js/|package\.json$|bun\.lock$|bun\.lockb$|biome\.jsonc$)'; then
		echo js
	fi

# Pull in new versions and report what's outdated.
update:
	bun update
	bun outdated
