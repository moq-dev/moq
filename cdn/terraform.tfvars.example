# Each tofu root module (common/, relay/, pub/, boy/) needs its own terraform.tfvars.
# Copy this file into each directory and fill in the values needed by that module.
#
# common/terraform.tfvars: linode_token, gcp_project, domain, webhook (optional)
# relay/terraform.tfvars:  linode_token, gcp_project, domain, email, ssh_keys
# pub/terraform.tfvars:    linode_token, gcp_project, domain, ssh_keys
# boy/terraform.tfvars:    linode_token, gcp_project, domain, ssh_keys

# The domain to use for the GeoDNS entry.
# Each node will register its own subdomain.
domain = "cdn.moq.dev"

# Linode API token (create at: https://cloud.linode.com/profile/tokens)
linode_token = "your-linode-api-token"

# GCP project ID for DNS management
# Note: GCP credentials will be read from ~/.config/gcloud or GOOGLE_APPLICATION_CREDENTIALS
gcp_project = "your-gcp-project-id"

# Email for LetsEncrypt notifications (relay only)
email = "admin@moq.dev"

# Your SSH public key for root access
ssh_keys = [
  "ssh-ed25519 AAAA... your-key-comment",
]

# Optional: Webhook URL for all alerts (Slack, Discord, etc.)
# webhook = "https://discord.com/api/webhooks/..."
