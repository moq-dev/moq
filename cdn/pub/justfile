# List all of the available commands.
default:
  just --list

# Get the hostname for the publisher
host:
	#!/usr/bin/env bash
	DOMAIN=$(cd .. && tofu output -raw domain)
	echo "pub.$DOMAIN"

# Deploy publisher
deploy:
	#!/usr/bin/env bash
	set -euo pipefail
	HOST=$(just host)
	echo "Deploying to $HOST..."

	echo "  Copying flake files to /var/lib/moq"
	rsync -az ../flake.nix ../flake.lock root@$HOST:/var/lib/moq/

	echo "  Copying secrets to /var/lib/moq"
	rsync -az ../secrets/ root@$HOST:/var/lib/moq/
	ssh root@$HOST "chmod -R 755 /var/lib/moq && chmod 600 /var/lib/moq/*.jwt"

	echo "  Copying systemd units to /etc/systemd/system/..."
	rsync -az hang-bbb-prepare.service root@$HOST:/etc/systemd/system/
	rsync -az --exclude='.gitignore' gen/ root@$HOST:/etc/systemd/system/
	rsync -az ../common/vacuum.service ../common/vacuum.timer ../common/memory-alert.sh root@$HOST:/etc/systemd/system/
	rsync -az --exclude='.gitignore' ../common/gen/ root@$HOST:/etc/systemd/system/

	echo "  Building and caching packages..."
	ssh root@$HOST "cd /var/lib/moq && nix build .#ffmpeg -o result && nix build .#moq-cli -o result-moq-cli && nix build .#jq -o jq"

	echo "  Enabling and starting services..."
	ssh root@$HOST "\
		systemctl daemon-reload && \
		systemctl enable hang-bbb-prepare.service && \
		systemctl enable hang-bbb.service && \
		systemctl enable vacuum.timer && \
		systemctl enable memory-alert.service && \
		systemctl start hang-bbb-prepare.service && \
		systemctl start vacuum.timer && \
		systemctl restart memory-alert.service && \
		systemctl restart hang-bbb.service"

# Check status of publisher
status:
	#!/usr/bin/env bash
	HOST=$(just host)
	echo "=== $HOST ==="
	ssh root@$HOST "systemctl status hang-bbb --no-pager"

# SSH into publisher
ssh:
	#!/usr/bin/env bash
	HOST=$(just host)
	ssh root@$HOST

# View logs from publisher
logs:
	#!/usr/bin/env bash
	HOST=$(just host)
	ssh root@$HOST "journalctl -u hang-bbb -f"
