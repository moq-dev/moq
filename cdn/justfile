mod common
mod relay
mod pub
mod boy

# List all of the available commands.
default:
  just --list

# Initialize tofu providers and backend for all modules
init:
	just common init
	just relay init
	just pub init
	just boy init

# Deploy all infrastructure and services
deploy:
	just common deploy
	just relay deploy-infra
	just pub deploy-infra
	just boy deploy-infra

# Pin relay and pub to their latest release tags
pin:
	just relay pin
	just pub pin

# Run health checks against all relay nodes
health:
	./health.sh

# Run health checks with webhook notification on failure
health-notify webhook:
	./health.sh {{webhook}}

# Check tofu formatting
check:
	just common check

# Fix tofu formatting
fix:
	just common fix
