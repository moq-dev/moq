[Unit]
Description=MoQ CDN monitor (memory + health checks)

[Service]
Type=simple
Environment=MONITOR_WEBHOOK=${webhook}
Environment=MONITOR_HEALTH_DOMAIN=${domain}
Environment=PATH=/var/lib/moq/pkg/bin:/usr/bin:/bin
ExecStart=/etc/systemd/system/monitor.sh
Restart=on-failure
RestartSec=10

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
