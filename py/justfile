#!/usr/bin/env just --justfile
#
# Language-specific recipes for the Python packages under py/. Invoked
# from the repo root as `just py <recipe>` via the `mod py` import.

set working-directory := '.'

default:
	just check

# Lint + format + maturin source build + pyright. `--no-install-workspace`
# installs the root dev group (ruff, maturin, pyright, pytest) without
# trying to pip-build moq-rs; `maturin develop` then installs moq-rs
# as an editable wheel with the rs/moq-ffi cdylib + uniffi bindings.
check:
	uv sync --no-install-workspace
	uv run --no-sync ruff check .
	uv run --no-sync ruff format --check .
	cd moq-rs && uv run --no-sync maturin develop --uv
	uv run --no-sync pyright

fix:
	uv sync --no-install-workspace
	uv run --no-sync ruff check --fix .
	uv run --no-sync ruff format .

test:
	uv sync --no-install-workspace
	cd moq-rs && uv run --no-sync maturin develop --uv
	uv run --no-sync pytest moq-rs/tests/

# Local dev build: produces an editable install of moq-rs (with the
# moq-ffi cdylib + uniffi bindings) into the workspace venv.
build:
	uv sync --no-install-workspace
	cd moq-rs && uv run --no-sync maturin develop --uv

# Full Python CI: lint + tests + build. Self-gates against BASE: exits 0
# fast if no Python (or rs/moq-ffi) files changed (so root `just ci` can
# call this unconditionally). Pass BASE="" to force-run.
ci BASE="origin/main":
	#!/usr/bin/env bash
	set -euo pipefail
	if [[ -n "{{ BASE }}" ]] && [[ -z "$(just changed {{ BASE }})" ]]; then
		echo "py: no changes vs {{ BASE }}; skipping."
		exit 0
	fi
	just check
	just test
	just build

# Print "py" if any Python file (or its rs/moq-ffi dependency) changed
# vs BASE; else print nothing. Source of truth for what counts as a
# "Python change".
changed BASE="origin/main":
	#!/usr/bin/env bash
	set -euo pipefail
	if ! merge_base=$(git merge-base "{{ BASE }}" HEAD 2>/dev/null); then
		echo py
		exit 0
	fi
	if git diff --name-only "$merge_base" | grep -qE '^(py/|pyproject\.toml$|uv\.lock$|rs/moq-ffi/)'; then
		echo py
	fi
